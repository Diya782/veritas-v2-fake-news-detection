# .env.example — copy to .env and fill in values

# Backend
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ML Model Config
# Set to "bert" to use DistilBERT (requires torch+transformers installed)
# Set to "tfidf" for fast TF-IDF only mode (default)
MODEL_MODE=tfidf

# Optional: path to fine-tuned BERT checkpoint
# BERT_MODEL_PATH=ml/saved_models/distilbert_fakenews

# Storage
# Options: "memory" (default, resets on restart) | "json" | "sqlite"
STORAGE_BACKEND=memory
